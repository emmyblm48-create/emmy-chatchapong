<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Emmy's Portfolio | Dev & BLM48 Idol</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Mitr:wght@300;400;500&family=Quicksand:wght@400;600&display=swap" rel="stylesheet">
</head>
<style>
  :root {
    --primary-pink: #fbcfe8;
    --primary-blue: #bae6fd;
    --text-color: #4b5563;
    --glass-bg: rgba(255, 255, 255, 0.7);
}

body {
    font-family: 'Quicksand', 'Mitr', sans-serif;
    margin: 0;
    color: var(--text-color);
    background: linear-gradient(135deg, #fdf2f8 0%, #eff6ff 100%);
    scroll-behavior: smooth;
}

/* Navbar Glassmorphism */
.navbar {
    position: fixed;
    top: 0; width: 100%;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.5rem 5%;
    background: var(--glass-bg);
    backdrop-filter: blur(10px);
    z-index: 1000;
}

.hero {
    height: 100vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
}

.hero h1 {
    font-size: 3.5rem;
    background: linear-gradient(to right, #ec4899, #3b82f6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

/* Grid System */
.grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    padding: 2rem 5%;
}

.card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
}

.card:hover {
    transform: translateY(-10px);
}

.card-img { height: 200px; }
.card-info { padding: 1.5rem; }

.tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: #f3f4f6;
    border-radius: 999px;
    font-size: 0.8rem;
}

.btn {
    padding: 0.8rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    margin: 0.5rem;
    display: inline-block;
}

.btn-primary { background: var(--primary-blue); color: #1e40af; }
.btn-secondary { background: var(--primary-pink); color: #9d174d; }
  </style>
<body>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="logo">Emmy.Chatchapong</div>
        <ul class="nav-links">
            <li><a href="#web-dev">Web Dev</a></li>
            <li><a href="#blm48">BLM48</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <header class="hero">
        <div class="hero-content">
            <h1>Dreaming & Coding</h1>
            <p>Web Developer & Producer of BLM48</p>
            <div class="hero-buttons">
                <a href="#web-dev" class="btn btn-primary">ดูผลงานเว็บ</a>
                <a href="#blm48" class="btn btn-secondary">BLM48 Gallery</a>
            </div>
        </div>
    </header>

    <!-- Portfolio Section: Web Development -->
    <section id="web-dev" class="section">
        <h2 class="section-title">Web Development Projects</h2>
        <div class="grid-container">
            <!-- ตัวอย่าง Card ผลงานเว็บ -->
            <div class="card">
                <div class="card-img" style="background-color: #e0f2fe;"></div>
                <div class="card-info">
                    <h3>DormCare</h3>
                    <p>Dormitory Management System built with FlutterFlow & Supabase</p>
                    <span class="tag">FlutterFlow</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Portfolio Section: BLM48 -->
    <section id="blm48" class="section pink-bg">
        <h2 class="section-title">BLM48 Cover Works</h2>
        <div class="grid-container">
            <!-- ตัวอย่าง Card ผลงานไอดอล -->
            <div class="card idol-card">
                <div class="card-img" style="background-color: #fce7f3;"></div>
                <div class="card-info">
                    <h3>Emmy BLM48 Zepeto Idol Group Cover</h3>
                    <p>Virtual Setlist - Producer & Center</p>
                    <span class="tag">ZEPETO</span>
                </div>
            </div>
        </div>
    </section>

</body>
</html>
